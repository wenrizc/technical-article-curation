# DeepSeek 接入配置
# DeepSeek 平台的 API Key 先写到这个变量里，当前代码从 `OPENAI_API_KEY` 读取。
OPENAI_API_KEY=your_deepseek_api_key_here
TAC_BASE_URL=https://api.deepseek.com
TAC_MODEL=deepseek-v4-flash

# 本地运行默认值
TAC_STATE_DB=data/state.db
TAC_SOURCES_PATH=config/sources.yaml
TAC_PUBLIC_DIR=public
TAC_MAX_RETRY=3
TAC_CRAWLER4AI_ENABLED=true
TAC_FETCH_DELAY_SECONDS=1
TAC_EVALUATION_MAX_ATTEMPTS=3
TAC_PROMPT_LANGUAGE=zh-CN
TAC_AUTO_MIGRATE=true

# 2 核 2GB 默认并发和资源限制
TAC_HTTP_MAX_CONCURRENCY=16
TAC_JOB_MAX_CONCURRENCY=1
TAC_JOB_QUEUE_LIMIT=8
TAC_FETCH_MAX_CONCURRENCY=1
TAC_EVALUATE_MAX_CONCURRENCY=1
TAC_DISCOVER_MAX_CONCURRENCY=2
TAC_MAX_REQUEST_BODY_BYTES=1048576
TAC_FETCH_TIMEOUT_SECONDS=90
TAC_AI_TIMEOUT_SECONDS=90
TAC_JOB_TIMEOUT_SECONDS=1800
TAC_FETCH_MAX_MARKDOWN_BYTES=2097152
TAC_JOB_HISTORY_LIMIT=100
TAC_DB_BUSY_TIMEOUT_MS=5000

# 可选测试覆盖项
# TAC_AI_RESPONSE_PATH=
# TAC_FETCH_FIXTURE_PATH=
# TAC_PROMPT_PATH=
# TAC_FEW_SHOT_DIR=
